# Random 32+ char string. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# Where to bind the HTTP server (Caddy will reverse-proxy in front)
PORT=3000
HOST=127.0.0.1

# Path to the SQLite file (defaults to ./data/app.db)
DB_PATH=./data/app.db

# CLI binaries — change if your CLIs are installed under different names/paths
CLI_CLAUDE=claude
CLI_CODEX=codex
CLI_GEMINI=gemini
CLI_GROK=grok

# Per-CLI invocation timeout (ms). Round 5 of roundtable can be long.
CLI_TIMEOUT_MS=600000

# Optional: limit which working directory the CLIs run in
CLI_CWD=/tmp
