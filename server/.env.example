# Random 32+ char string. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# Where to bind the HTTP server (Caddy will reverse-proxy in front)
PORT=3000
HOST=127.0.0.1

# Path to the SQLite file (defaults to ./data/app.db)
DB_PATH=./data/app.db

# CLI binaries — change if your CLIs are installed under different names/paths
CLI_CLAUDE=claude
CLI_CODEX=codex
CLI_GEMINI=gemini

# Grok has no official CLI; we hit the xAI REST API directly.
# Get a key at https://console.x.ai → API keys
XAI_API_KEY=xai-replace-me

# Per-CLI invocation timeout (ms). Round 5 of roundtable can be long.
CLI_TIMEOUT_MS=600000

# Optional: limit which working directory the CLIs run in
CLI_CWD=/tmp

# === Oracle ATP backup (optional — leave ORACLE_USER blank to disable) ===
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=aibase_low
ORACLE_WALLET_DIR=/home/ubuntu/oracle_wallet
ORACLE_WALLET_PASSWORD=

# === SMTP (for password-reset emails) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# === Public URL (used in password-reset email links) ===
PUBLIC_URL=https://chat.ted-h.com
